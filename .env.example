# Server-only secrets (never commit `.env*` tracked secrets; `.env.local` is gitignored)

# Gemini (recommended if key starts with AIza…) — `@ai-sdk/google`
GOOGLE_GENERATIVE_AI_API_KEY=
# Alternate name also accepted:
# GEMINI_API_KEY=

GOOGLE_AI_MODEL=gemini-2.5-flash

# OpenAI (optional second provider — used only if Gemini key absent)
OPENAI_API_KEY=

# OPTIONAL model id forwarded to `@ai-sdk/openai`
OPENAI_MODEL=gpt-4o-mini

# --- Phase A assistant quota (KV + signed cookie) ---
# Required in production (unless using QUOTA_DISABLED_LOCAL in dev only).
# Generate e.g. `openssl rand -hex 32`
QUOTA_COOKIE_SECRET=

# Vercel KV (linked project) or Upstash Redis REST — either pair works:
KV_REST_API_URL=
KV_REST_API_TOKEN=
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Dev only: skip quota + cookie requirement when NODE_ENV=development (never enable in prod).
# QUOTA_DISABLED_LOCAL=0

# Set truthy-ish to hard-stop completions (deploy kill-switch).
DISABLE_CHAT=0
